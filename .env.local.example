# Firebase config for Picture Twirl (Vite env vars).
# Copy this file to `.env.local` and fill in your project's values:
#   cp .env.local.example .env.local
#
# `.env.local` is gitignored. Alternatively, set window.__FIREBASE_CONFIG__
# in index.html (that takes priority over these vars). See firebase.js.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
